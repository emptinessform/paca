{
  "name": "@paca/plugin-sdk",
  "version": "0.1.0",
  "description": "Paca Plugin SDK — frontend helpers for building Paca micro-frontend plugins",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "@tanstack/react-query": ">=5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@tanstack/react-query": "^5.99.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "typescript": "^5.8.3",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0"
  }
}
